{
  "$schema": "https://opencode.ai/config.json",
  "autoshare": false,
  "autoupdate": true,
  "enabled_providers": [
    "anthropic",
    "openai",
    "github-copilot"
  ],
  "mcp": {
    "linear": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "mcp-remote",
        "https://mcp.linear.app/sse"
      ],
      "enabled": true
    }
  },
  "plugin": [
    [
      "@plannotator/opencode@latest",
      {
        "workflow": "manual"
      }
    ]
  ],
  "lsp": true,
  "formatter": true
}
